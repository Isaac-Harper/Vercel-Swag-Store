{
  "name": "next-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write src/* tests/*",
    "prettier": "prettier -c src/* tests/*",
    "test": "pnpm test:e2e && pnpm test:api && pnpm test:unit",
    "test:setup": "playwright install",
    "test:e2e": "playwright test --config tests/playwright.e2e-config.ts",
    "test:api": "playwright test --config tests/playwright.api-config.ts",
    "test:unit": "jest --config tests/jest.unit-config.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/postcss": "^4.0.8",
    "geist": "^1.7.0",
    "next": "16.0.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "prettier": "@monogram/prettier-config",
  "devDependencies": {
    "@monogram/eslint-config": "^0.1.6",
    "@monogram/prettier-config": "^0.3.4",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.47",
    "prettier": "^3.5.1",
    "tailwindcss": "^4.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
